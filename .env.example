# Generate with: openssl rand -hex 32
SESSION_SECRET=

# SendGrid — required in production, optional in dev (magic links print to console instead)
SENDGRID_API_KEY=
FROM_EMAIL=

# Full origin URL — defaults to http://localhost:3000 if not set
APP_URL=https://your-app.herokuapp.com

# Comma-separated individual emails allowed in beyond @thechisholmlegacyproject.org
ALLOWED_EMAILS=
